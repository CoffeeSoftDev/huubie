# Bloquea acceso HTTP a TODO en esta carpeta.
# Las credenciales solo deben leerse desde PHP, nunca por URL.

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>

# Doble seguro: bloquear por extension comun de secretos
<FilesMatch "\.(env|json|key|pem|cert|crt|p12|pfx)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
