# Copia este archivo a .env y rellena los valores.
# NO subas el .env real al repositorio.

# Ollama Cloud (https://ollama.com/settings/keys)
OLLAMA_API_KEY="tu_api_key_aqui"
OLLAMA_BASE_URL="https://ollama.com"
OLLAMA_DEFAULT_MODEL="qwen3-coder:480b-cloud"
OLLAMA_TIMEOUT=120

# Opcional: ruta a CA bundle (en blanco para usar el del sistema)
OLLAMA_CA_BUNDLE=""

# OpenRouter - obten tu key en openrouter.ai/keys
OPENROUTER_API_KEY="tu_api_key_aqui"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_DEFAULT_MODEL="anthropic/claude-sonnet-4"
OPENROUTER_VISION_MODEL="google/gemini-2.0-flash-001"
OPENROUTER_TIMEOUT=120

# Opcional: ruta a CA bundle (en blanco para usar el del sistema)
OPENROUTER_CA_BUNDLE=""

# GitHub Projects - PAT (classic o fine-grained) con scope read:project
# Genera uno en https://github.com/settings/tokens
GITHUB_TOKEN="tu_token_aqui"
GITHUB_API_TIMEOUT=30

# MySQL - el chat lee el esquema de las bases locales y ejecuta SELECT de solo lectura.
# Credenciales server-side: NUNCA se mandan al modelo. Default: root local de WAMP.
DB_HOST="127.0.0.1"
DB_PORT=3306
DB_USER="root"
DB_PASS=""
# Tope de filas por SELECT en vivo.
DB_MAX_ROWS=200
# Lista blanca de bases expuestas, separadas por coma. Vacio = todas las no-sistema.
DB_ALLOWED_SCHEMAS=""
